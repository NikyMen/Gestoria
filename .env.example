# Clave de API de Anthropic (Claude) para las funciones de IA
# Consíguela en https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Autenticación (login). Valores por defecto en desarrollo: admin / admin
AUTH_USER=admin
AUTH_PASSWORD=admin
# Secreto para firmar la cookie de sesión (cambialo en producción)
AUTH_SECRET=cambia-este-secreto-largo-y-aleatorio
